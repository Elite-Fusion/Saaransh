# ============================================================
# Saaransh AI — Backend Environment Variables (EXAMPLE)
# Copy this file to `.env` and fill in real values locally.
# NEVER commit a real .env to git.
# ============================================================

# ---- App ----
APP_NAME=Saaransh AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database (Supabase Postgres) ----
# Example format:
# DATABASE_URL=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=https://avnljqrvnthtxtnhjgkf.supabase.co
DB_ECHO=false

# ---- CORS ----
# Comma-separated list of allowed origins (or use the default in settings.py).
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============================================================
# AI (Phase 5)
# ============================================================
# The provider abstraction supports Gemini today; Claude, OpenAI,
# Groq, and OpenRouter will plug into the same interface in later
# phases. To switch providers later, change AI_PROVIDER and set
# the matching <PROVIDER>_API_KEY.

# 'gemini' is the only supported value in Phase 5. Other values
# cause a clear startup error pointing at this file.
AI_PROVIDER=gemini

# Google AI Studio key — https://aistudio.google.com/apikey
# Leave empty in shared / committed environments. The Settings
# validator refuses to start the app with an empty key.
GEMINI_API_KEY=AQ.Ab8RN6LslKfxr8I3RCnCdZjK4KwXrdw9RTLrq7EERuqFQbnlt

# Free-tier friendly default; override for production.
GEMINI_MODEL=gemini-2.0-flash

# Per-request timeout (seconds). The tenacity retry policy uses
# this only as an upper bound on each individual attempt.
AI_REQUEST_TIMEOUT_SECONDS=30

# Number of retry attempts on transient failures (429, 5xx, timeout).
# Total attempts = 1 + AI_MAX_RETRIES.
AI_MAX_RETRIES=3

# Optional override for the prompts directory. Empty = use the
# default `backend/ai/prompts/`.
AI_PROMPTS_DIR=
